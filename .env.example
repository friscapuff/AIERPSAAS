# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=aierp
DB_PASSWORD=aierp_password
DB_DATABASE=aierp
DB_LOGGING=false
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_REFRESH_EXPIRES_IN=7d

# Application
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=debug
