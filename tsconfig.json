{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "lib": ["ES2021"],
    "declaration": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@api/*": ["apps/api/src/*"],
      "@modules/*": ["apps/api/src/modules/*"],
      "@common/*": ["apps/api/src/common/*"],
      "@config/*": ["apps/api/src/config/*"],
      "@database/*": ["libs/database/src/*"],
      "@auth/*": ["libs/auth/src/*"],
      "@logger/*": ["libs/logger/src/*"],
      "@shared/*": ["libs/shared/src/*"],
      "@validation/*": ["libs/validation/src/*"]
    }
  },
  "include": ["apps/**/*", "libs/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
